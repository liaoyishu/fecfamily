<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>你好</title>
</head>
<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #1e293b, #0f172a);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            padding: 20px;
        }

        h1 {
            font-size: 32px;
            margin-bottom: 16px;
            color: #f8fafc;
            text-shadow: 0 0 10px rgba(59, 130, 246, 0.3);
        }

        p {
            font-size: 18px;
            color: #cbd5e1;
            margin-bottom: 40px;
            max-width: 600px;
            line-height: 1.6;
        }

        .btn {
            background: linear-gradient(90deg, #3b82f6, #1d4ed8);
            color: white;
            padding: 14px 32px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.6);
        }

        .btn:active {
            transform: translateY(0);
        }
    </style>
<body>
  <h1 style="text-align:center;">一家人官网</h1>
  <p>大家好</p>
</body>
</html>
